# ═══════════════════════════════════════════════
# Lantern Agent — Environment Configuration
# ═══════════════════════════════════════════════

# Shared
NODE_ENV=development
DATABASE_URL=postgres://postgres:postgres@localhost:5432/lantern
REDIS_URL=redis://localhost:6379
APP_URL=http://localhost:3000
LANTERN_EXECUTION_MODE=live
LANTERN_LOCAL_STATE_FILE=

# OKX Onchain OS
OKX_PROJECT_ID=
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=

# X Layer
OKX_CHAIN_ID=196
RPC_URL=https://xlayerrpc.okx.com
EXPLORER_URL=https://www.okx.com/web3/explorer/xlayer

# Wallet
PRIVATE_KEY=0x...
OKX_WALLET_ADDRESS=0x...

# Risk Controls
DRAWDOWN_STOP_PCT=0.2
POSITION_STOP_LOSS_PCT=0.3
MAX_TOTAL_EXPOSURE_PCT=0.5
MAX_TOKEN_EXPOSURE_PCT=0.3
MAX_POSITIONS=10
MAX_TRADE_PCT=0.1
MIN_TRADE_USD=5
INITIAL_BANKROLL_USD=500

# Agent Loop
AGENT_POLL_INTERVAL_SECONDS=60
SYNC_INTERVAL_SECONDS=30

# Pulse
PULSE_MIN_LIQUIDITY_USD=5000
PULSE_MAX_CANDIDATES=12

# Dashboard
ADMIN_PASSWORD=change-me
ORCHESTRATOR_INTERNAL_URL=http://localhost:4001
ORCHESTRATOR_INTERNAL_TOKEN=replace-me

# Artifacts
ARTIFACT_STORAGE_ROOT=runtime-artifacts
