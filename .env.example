RPC_URL=https://xlayerrpc.okx.com
EXPLORER_URL=https://www.okx.com/web3/explorer/xlayer

# Polymarket (used by poly-trade.ts)
POLY_PRIVATE_KEY=0x...
POLY_SIGNER_ADDRESS=0x...
POLY_FUNDER_ADDRESS=0x...
POLY_SIGNATURE_TYPE=2
POLY_CHAIN_ID=137
POLY_HOST=https://clob.polymarket.com

# Artifacts
ARTIFACT_STORAGE_ROOT=runtime-artifacts
