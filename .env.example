# OKX Onchain OS (used by agent-demo.ts via `onchainos` CLI)
OKX_PROJECT_ID=
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=

# X Layer (used by agent-onchain.ts)
